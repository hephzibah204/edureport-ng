# --- Super Admin ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeNow_Use_At_Least_12Chars

# --- Encryption (required for 2FA, payment keys, portal PINs, etc.) ---
# Generate with: php -r "echo base64_encode(random_bytes(32));"
ENCRYPTION_KEY=RXSGHX1m9LAd/e3rMUipifZb4eafdDF0kLU2YIh/aHA=

# --- Session ---
SESSION_NAME=ReportSheetSESSID

# --- UI Redirect URLs ---
ADMIN_UI_URL=/adminpanel/bootstrap.html
SCHOOL_UI_URL=/app.html

# --- CORS ---
CORS_ORIGIN=http://localhost:8080,https://reportsheet.com.ng,https://www.reportsheet.com.ng

# --- Public API URL ---
PUBLIC_API_URL=http://localhost:3010,https://reportsheet.com.ng,https://www.reportsheet.com.ng

# --- AI / LLM Providers ---
AI_ENABLED=false
AI_PRIORITY_LIST=gemini,openrouter,openai

# Google Gemini
GOOGLE_API_KEY=
AI_GEMINI_MODEL=gemini-1.5-flash

# OpenRouter
OPEN_ROUTER_API_KEY=
AI_OPENROUTER_MODEL=google/gemini-flash-1.5

# OpenAI (Standard)
OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini
AI_OPENAI_BASE_URL=https://api.openai.com/v1

# Legacy / Fallback (kept for backward compatibility)
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_API_KEY=

# --- PDF Rendering ---
PDF_RENDERER=edge
PDF_BROWSER_BIN=msedge

# --- SMS Providers ---
# Provider: termii or twilio (leave empty to disable)
SMS_PROVIDER=

# Termii (Nigeria)
TERMII_API_KEY=
TERMII_SENDER_ID=ReportSheet

# Twilio (Global)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- SMTP / Email ---
SMTP_FROM_NAME=EduReport NG
SMTP_FROM_EMAIL=notifications@edureport.ng

# Optional: If your server supports authenticated SMTP:
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your_smtp_password
# SMTP_ENCRYPTION=tls

# --- Support Contacts ---
SUPPORT_WHATSAPP=2348037000456
SUPPORT_EMAIL=support@edureport.ng
SUPPORT_PHONE=+234 803 700 0456

# --- Report Export ---
REPORT_EXPORT_TTL_DAYS=30

# --- SSL / Security ---
# SSL_CA_BUNDLE=/path/to/ca-bundle.crt

# --- Debug ---
DEBUG=false