DirectoryIndex index.html index.php

RewriteEngine On

# Security headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Block direct access to backend source directories
RewriteRule ^backend/ - [F,L]
RewriteRule ^php-backend/ - [F,L]

# API routes - forward to PHP backend entry point
RewriteRule ^api/(.*)$ php-backend/public/index.php [QSA,L]

# Explicit: serve index.html for directory-like paths
RewriteCond %{REQUEST_URI} ^(.+)/$
RewriteCond %{DOCUMENT_ROOT}%1/index.html -f
RewriteRule ^(.+)/$ $1/index.html [L]

RewriteCond %{REQUEST_URI} ^(.+[^/])$
RewriteCond %{DOCUMENT_ROOT}%1/index.html -f
RewriteRule ^(.+[^/])$ $1/index.html [L]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Hide .html extension for frontend pages
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

# Redirect direct .html access to clean URL
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R=301]

# Fallback to landing page
RewriteRule ^ index.html [L]
