{
  "name": "edureport-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <25"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:dbpush": "prisma db push --schema prisma/schema.prisma",
    "prisma:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma",
    "prisma:dbpush:sqlite": "prisma db push --schema prisma/schema.sqlite.prisma",
    "prisma:generate:pg": "prisma generate --schema prisma/schema.postgres.prisma",
    "prisma:dbpush:pg": "prisma db push --schema prisma/schema.postgres.prisma",
    "prisma:migrate:pg": "prisma migrate deploy --schema prisma/schema.postgres.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@prisma/client": "^5.14.0",
    "argon2": "^0.41.1",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.7",
    "pino": "^9.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.6.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.2",
    "prisma": "^5.14.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.2"
  }
}
