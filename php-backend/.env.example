DB_DSN=sqlite:storage/edureport.sqlite

# Production (MySQL/MariaDB): remove DB_DSN and set these instead
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=edureport
# DB_USER=root
# DB_PASS=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeNow_Use_At_Least_12Chars

ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Where to send admins after they log in (local dev default)
ADMIN_UI_URL=http://127.0.0.1:8080/admin.html

# Where to send school users after they log in (local dev default)
SCHOOL_UI_URL=http://127.0.0.1:8080/app.html
CORS_ORIGIN=http://127.0.0.1:8080,http://127.0.0.1:8085,http://localhost:8080,http://localhost:8085

# AI settings (optional)
AI_ENABLED=false
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=15000
AI_API_KEY=

# If using OpenRouter
OPEN_ROUTER_API_KEY=

# If using Gemini (not OpenAI-compatible)
GOOGLE_API_KEY=

# PDF rendering (enterprise grade)
PDF_RENDERER=edge
PDF_BROWSER_BIN=msedge

# SMS (Termii)
SMS_PROVIDER=
TERMII_API_KEY=
TERMII_SENDER_ID=EduReport

# Public base URL for download links
PUBLIC_API_URL=http://127.0.0.1:3010

# Report export link TTL
REPORT_EXPORT_TTL_DAYS=30
