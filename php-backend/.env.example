# ============================================================
# EduReport NG — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# For local dev (SQLite):
DB_DSN=sqlite:storage/edureport.sqlite

# For production (MySQL/MariaDB on cPanel):
# Comment out DB_DSN above and uncomment these:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=your_cpanel_db_name
# DB_USER=your_cpanel_db_user
# DB_PASS=your_cpanel_db_password

# --- Super Admin ---
ADMIN_EMAIL=admin@yourdomain.com
# Must be at least 12 characters
ADMIN_PASSWORD=ChangeMeNow_Use_At_Least_12Chars

# --- Encryption (required for 2FA, payment keys, etc.) ---
# Generate with: php -r "echo base64_encode(random_bytes(32));"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# --- UI Redirect URLs ---
# Where to send admins after login (use relative path for same-origin)
ADMIN_UI_URL=/adminpanel/bootstrap.html
# Where to send school users after login
SCHOOL_UI_URL=/app.html

# --- CORS ---
# Comma-separated list of allowed origins.
# For same-origin deployment (frontend + API on same domain),
# include only your domain(s). For subdomain-based multi-tenant,
# add the wildcard form: https://*.edureport.ng (handled at nginx level).
# For local dev, add http://localhost:8080,http://127.0.0.1:8080
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com,http://localhost:8080

# --- Public API URL ---
# Used for generating download links, report export URLs, etc.
# For same-origin deployment, leave empty or set to your domain.
PUBLIC_API_URL=

# --- AI Settings (optional) ---
AI_ENABLED=false
AI_PRIORITY_LIST=gemini,openrouter,openai

# Google Gemini
GOOGLE_API_KEY=
AI_GEMINI_MODEL=gemini-1.5-flash

# OpenRouter
OPEN_ROUTER_API_KEY=
AI_OPENROUTER_MODEL=google/gemini-flash-1.5

# OpenAI (Standard)
OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini
AI_OPENAI_BASE_URL=https://api.openai.com/v1

# --- PDF Rendering ---
# Options: edge, chrome, msedge, browser
# On shared cPanel, headless browser may not be available.
# Set to empty or remove to disable PDF generation.
PDF_RENDERER=edge
PDF_BROWSER_BIN=msedge

# --- SMS (optional) ---
# Provider: termii or twilio
SMS_PROVIDER=
TERMII_API_KEY=
TERMII_SENDER_ID=ReportSheet
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- SMTP / Email (optional) ---
SMTP_FROM_NAME=EduReport NG
SMTP_FROM_EMAIL=notifications@yourdomain.com

# --- Support Contacts ---
SUPPORT_WHATSAPP=2348037000456
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_PHONE=+234 803 700 0456

# --- Report Export ---
# How many days before report export links expire
REPORT_EXPORT_TTL_DAYS=30

# --- Security ---
# Set to true to redirect all HTTP requests to HTTPS
FORCE_HTTPS=false

# --- Debug (set to false in production) ---
DEBUG=false
